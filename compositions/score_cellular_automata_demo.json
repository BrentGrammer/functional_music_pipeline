      "329.63:0.3"
    ]
  },
  "composition": {
    "voices": [
      {
        "phrases": [
          {
            "comment": "Original: 6 steady tones at the same pitch.",
            "motifs": ["steady_tone"]
          },
          {
            "comment": "Rule 30 on amplitude: creates a chaotic loud/quiet pattern. Some notes drop to near-silence while others stay loud.",
            "motifs": ["steady_tone"],
            "transforms": [
