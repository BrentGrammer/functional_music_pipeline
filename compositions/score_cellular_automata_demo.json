                  "seed": 42
                }
              }
            ]
          },
          {
            "comment": "Rule 30 on frequency: pitches jump up or down creating a melodic contour from chaos.",
            "motifs": ["steady_tone"],
            "transforms": [
              {
                "name": "cellular_automata",
