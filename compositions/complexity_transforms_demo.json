            "motifs": ["melody"],
            "transforms": [
              {
                "name": "cellular_automata",
                "params": {
                  "dimension": "frequency",
                  "rule": 30,
                  "generations": 5,
                  "max_deviation": 0.2
                }
              }
            ]
          },
          {
