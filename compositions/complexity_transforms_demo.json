            "transforms": [
              {
                "name": "erosion",
                "params": { "dimension": "amplitude" }
              }
            ]
          },
          {
            "comment": "7. Erosion (Frequency): Melodic collapse towards the first note's pitch.",
            "motifs": ["melody"],
            "transforms": [
              {
                "name": "erosion",
                "params": { "dimension": "frequency" }
              }
            ]
          }
