          },
          {
            "comment": "Pad silence: adds 1.0 second of silence after the melody. Unlike delay, this also supports padding at the end.",
            "motifs": [
              "melody"
            ],
            "transforms": [
              {
                "name": "pad_silence",
                "params": {
                  "seconds": 1.0,
                  "position": "end"
                }
              }
            ]
          }
        ]
      }
    ],
    "score_transforms": []
