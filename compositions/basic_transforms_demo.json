            "motifs": [
              "melody"
            ]
          },
          {
            "comment": "Reverse (retrograde): plays the notes in reverse order.",
            "motifs": [
              "melody"
            ],
            "transforms": [
              {
                "name": "reverse"
              }
            ]
          },
          {
