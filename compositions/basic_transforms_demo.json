            "motifs": [
              "melody"
            ],
            "transforms": [
              {
                "name": "transpose",
                "params": {
                  "semitones": 7
                }
              }
            ]
          },
          {
            "comment": "Scale duration: doubles the length of each note for a slower result.",
            "motifs": [
              "melody"
            ],
            "transforms": [
              {
                "name": "scale",
                "params": {
                  "dimension": "duration",
                  "factor": 2.0
                }
              }
            ]
          },
          {
            "comment": "Scale amplitude: reduces volume to 30%.",
            "motifs": [
              "melody"
            ],
            "transforms": [
              {
                "name": "scale",
                "params": {
                  "dimension": "amplitude",
                  "factor": 0.3
                }
              }
            ]
          },
          {
            "comment": "Delay: prepends 1.5 seconds of silence before the melody starts. This is the shorthand alias for pad_silence at position start.",
            "motifs": [
              "melody"
            ],
            "transforms": [
