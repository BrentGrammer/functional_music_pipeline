            "transforms": [
              {
                "name": "feigenbaum_sequence",
                "params": { "dimension": "frequency" }
              }
            ]
          },
          {
            "comment": "4. Phrase Golden Ratio Grow: Scales this phrase's duration to be 1.618x the previous phrase's duration.",
            "motifs": ["melody"],
            "transforms": [
              {
                "name": "phrase_golden_ratio_grow",
                "params": { "dimension": "duration" }
              }
            ]
          },
          {
            "comment": "5. Phrase Golden Ratio Shrink: Scales this phrase's duration to be 1/1.618 of the previous phrase.",
            "motifs": ["melody"],
            "transforms": [
              {
                "name": "phrase_golden_ratio_shrink",
                "params": { "dimension": "duration" }
              }
            ]
          },
          {
            "comment": "6. Phrase Feigenbaum Grow: Scales this phrase's duration to be 4.669x the previous phrase.",
            "motifs": ["melody"],
            "transforms": [
