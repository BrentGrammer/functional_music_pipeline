{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4-mini",
  "autoupdate": false,
  "share": "disabled",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uv",
        "tool",
        "run",
        "--python",
        "3.13",
        "--from",
        "serena-agent@latest",
        "--prerelease=allow",
        "serena",
        "start-mcp-server",
        "--project",
        "--context=ide",
        "--open-web-dashboard=false"
      ],
      "enabled": true,
      "environment": {
        "SERENA_USAGE_REPORTING": "false"
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      "coverage/**",
      ".env",
      ".env.*"
    ]
  }
}
