{
  "mcpServers": {
    "exa": {
      "httpUrl": "https://mcp.exa.ai/mcp"
    },
    "serena": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/home/sandbox/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "."
      ],
      "trust": true,
      "timeout": 120000
    }
  }
}